<Window x:Class="GAVETA_DA_SORTE_WPF.EsqueceuSenha"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alterar Senha" Height="380" Width="400"
        WindowStyle="None"                  
        AllowsTransparency="True"           
        Background="Transparent"            
        WindowStartupLocation="CenterOwner" 
        ShowInTaskbar="False">

    <Grid Margin="15">
        <Border CornerRadius="20" BorderThickness="1" BorderBrush="#EEEEEE" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>

            <Grid Margin="25">
                <StackPanel Margin="0,0,0,-20">
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="ALTERAR SENHA" FontSize="16" FontWeight="ExtraBold" Foreground="#2D2D2D" HorizontalAlignment="Left"/>
                        <Button Content="✕" Width="30" HorizontalAlignment="Left"
                                Background="Transparent" BorderThickness="0" Foreground="Silver" FontSize="14"
                                Click="BtnFechar_Click" Cursor="Hand" Margin="288,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Novo Usuário" FontSize="11" Foreground="Gray" Margin="5,0,0,3"/>
                    <Border Height="40" Background="#F9F9F9" CornerRadius="10" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,12">
                        <TextBox x:Name="txtUsuarioRecuperar" BorderThickness="0" Background="Transparent" 
                                 VerticalContentAlignment="Center" Padding="12,0" FontSize="14"/>
                    </Border>

                    <TextBlock Text="Nova Senha" FontSize="11" Foreground="Gray" Margin="5,0,0,3"/>
                    <Border Height="40" Background="#F9F9F9" CornerRadius="10" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,12">
                        <PasswordBox x:Name="txtNovaSenha" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" Padding="12,0" FontSize="14"/>
                    </Border>

                    <TextBlock Text="Confirmar Nova Senha" FontSize="11" Foreground="Gray" Margin="5,0,0,3"/>
                    <Border Height="40" Background="#F9F9F9" CornerRadius="10" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,20">
                        <PasswordBox x:Name="txtConfirmarSenha" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" Padding="12,0" FontSize="14"/>
                    </Border>

                    <Button x:Name="btnAlterarSenha" Content="ALTERAR SENHA" Height="45" Width="200" 
                            Background="#2D2D2D" Foreground="White" FontWeight="Bold" Cursor="Hand"
                            Click="btnAlterarSenha_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>