<Window x:Class="GAVETA_DA_SORTE_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gaveta da Sorte - Login" Height="450" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Border CornerRadius="25" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#2D2D2D" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="25,0,0,25">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1D5D4A" Offset="0"/>
                            <GradientStop Color="#2E3A46" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image Margin="-83,-10,-85,65" Source="/ChatGPT Image 11 de mar. de 2026, 01_54_35.png" Stretch="Fill" Opacity="0.85"/>
                </Border>

                <Grid Grid.Column="1" Margin="40,20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="LOGIN" FontSize="24" FontWeight="ExtraBold" Foreground="#2E3A46" Margin="0,0,0,30"/>

                        <TextBlock Text="Usuário" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D" Margin="5,0,0,3"/>
                        <Border Height="40" Background="#F2F2F2" CornerRadius="10" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,15">
                            <TextBox x:Name="txtUSUARIO" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" Padding="12,0" FontSize="14" Foreground="#2E3A46"/>
                        </Border>

                        <TextBlock Text="Senha" FontSize="11" FontWeight="Bold" Foreground="#7F8C8D" Margin="5,0,0,3"/>
                        <Border Height="40" Background="#F2F2F2" CornerRadius="10" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,5">
                            <PasswordBox x:Name="SENHA" BorderThickness="0" Background="Transparent" 
                                         VerticalContentAlignment="Center" Padding="12,0" FontSize="14"/>
                        </Border>

                        <Button x:Name="btnEsqueceuSenha" Content="Esqueceu a senha?" 
                                HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                                Foreground="#1D5D4A" FontSize="11" Cursor="Hand" Click="btnEsqueceuSenha_Click" Margin="0,0,5,25"/>

                        <Button x:Name="btnLOGAR" Content="ACESSAR CONTA" Height="45" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="btnLOGAR_Click" Background="#FF1D5D4A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" CornerRadius="12" Background="#1D5D4A">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#2E3A46"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Não tem conta? Cadastre-se" Background="Transparent" BorderThickness="0" 
                                Foreground="#7F8C8D" FontSize="11" Margin="0,20,0,0" Cursor="Hand" Click="BtnIrParaCadastro_Click"/>
                    </StackPanel>
                </Grid>

                <Button Content="✕" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="0,15,20,0" Background="Transparent" BorderThickness="0" 
                        Foreground="Silver" FontSize="18" Click="BtnFechar_Click" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>