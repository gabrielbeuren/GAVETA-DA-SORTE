<Window x:Class="GAVETA_DA_SORTE_WPF.TelaDeposito"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Depósito" Height="200" Width="250"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="20" Background="#2E3A46" BorderBrush="#9CE6D4" BorderThickness="2">
        <Grid Margin="15">
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Background="Transparent" BorderThickness="0" Foreground="White" 
                    Click="BtnFechar_Click" Cursor="Hand" Margin="0,-5,0,0"/>

            <TextBlock Text="VALOR DO DEPÓSITO:" Foreground="#9CE6D4" FontSize="10" FontWeight="Bold" 
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0"/>

            <Border Width="180" Height="35" Background="#F2F2F2" CornerRadius="8" 
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,55,0,0">
                <TextBox x:Name="txtValorDeposito" Text="0,00" BorderThickness="0" Background="Transparent" 
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" 
                         FontSize="15" FontWeight="Bold" Foreground="#2E3A46" GotFocus="txt_GotFocus"/>
            </Border>

            <Button x:Name="btnConfirmarDeposito" Content="FINALIZAR DEPÓSITO" 
                    Width="180" Height="40" VerticalAlignment="Bottom" Margin="0,0,0,10" Cursor="Hand" 
                    Click="btnConfirmarDeposito_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#9CE6D4" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#1D5D4A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>