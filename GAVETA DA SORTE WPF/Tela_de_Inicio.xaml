<Window x:Class="GAVETA_DA_SORTE_WPF.Tela_de_Inicio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GAVETA_DA_SORTE_WPF"
        mc:Ignorable="d"
        Title="Tela_de_Inicio" Height="450" Width="600">

    <Grid>
        <TextBlock x:Name="txtOlaUsuario"
           FontSize="20"
           Margin="120,-16,0,56"
           HorizontalAlignment="Left"/>

        <Image x:Name="imgPerfil"
       Width="120"
       Height="120"
       Margin="25,26,0,288"
       HorizontalAlignment="Left"/>

        <Button x:Name="btnTrocarFoto"
        Content="Trocar Foto"
        Width="120"
        Height="30"
        Click="btnTrocarFoto_Click"
        HorizontalAlignment="Left" Margin="24,166,0,238"/>

        <Button x:Name="btnCriarGrupo"
        Content="Criar Grupo"
        Width="150"
        Height="40"
        Click="btnCriarGrupo_Click" Margin="10,231,440,163"/>
        <ListBox x:Name="ListaGrupos" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="24,294,447,29"/>
    </Grid>

</Window>
