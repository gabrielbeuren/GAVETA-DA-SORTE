<Window x:Class="GAVETA_DA_SORTE_WPF.CriarGrupo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Criar Grupo" Height="380" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="25" Background="#2E3A46" BorderBrush="#9CE6D4" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Button x:Name="btnFechar" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="0,15,20,0" Background="Transparent" BorderThickness="0" 
                    Foreground="White" FontSize="18" Cursor="Hand" Click="btnFechar_Click"/>

            <TextBlock Text="NOVO GRUPO" Foreground="White" FontSize="22" FontWeight="Black" 
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0"/>

            <TextBlock Text="NOME DO GRUPO:" Foreground="#9CE6D4" FontSize="10" FontWeight="Bold" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,110,0,0"/>

            <Border Width="280" Height="40" Background="#F2F2F2" CornerRadius="10" 
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,130,0,0">
                <TextBox x:Name="txtNomeGrupo" 
                         BorderThickness="0" 
                         Background="Transparent" 
                         VerticalContentAlignment="Center" 
                         Padding="15,0" 
                         FontSize="14" 
                         FontWeight="SemiBold" 
                         Foreground="#2E3A46"/>
            </Border>

            <TextBlock Text="Escolha um nome criativo para o seu grupo de sorte!" 
                       Foreground="Silver" FontSize="10" TextWrapping="Wrap" TextAlignment="Center"
                       Width="250" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,180,0,0"/>

            <Button x:Name="btnCriarGrupo" Content="CRIAR GRUPO AGORA" 
                    Width="280" Height="45" HorizontalAlignment="Center" VerticalAlignment="Top" 
                    Margin="0,250,0,0" Cursor="Hand" Click="btnCriarGrupo_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#9CE6D4" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#1D5D4A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>

        </Grid>
    </Border>
</Window>