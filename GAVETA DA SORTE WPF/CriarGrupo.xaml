<Window x:Class="GAVETA_DA_SORTE_WPF.CriarGrupo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GAVETA_DA_SORTE_WPF"
        mc:Ignorable="d"
        Title="CriarGrupo" Height="380" Width="400"
        WindowStartupLocation="CenterOwner">
    
    <Grid>
        <TextBox x:Name="txtNomeGrupo" HorizontalAlignment="Left" Margin="104,146,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="btnCriarGrupo" Content="Button" HorizontalAlignment="Left" Margin="164,250,0,0" VerticalAlignment="Top" Click="btnCriarGrupo_Click"/>
    </Grid>
</Window>
